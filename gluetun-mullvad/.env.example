# === Mullvad WireGuard ===
# Generate config at: https://mullvad.net/en/account/wireguard-config
MULLVAD_ADDRESS=
MULLVAD_COUNTRY=Sweden

# === Network ===
LAN_NETWORK=192.168.1.0/24
TAILBOX_NETWORK=tailbox-net
TZ=UTC

# === DNS ===
# DNS mode: "split" (default) | "mullvad" | "custom"
DNS_MODE=split

# Split mode: local domain resolved via LAN, everything else via Mullvad
DNS_LOCAL_DOMAIN=lan.example.com
DNS_LOCAL_SERVER=192.168.1.1

# Custom mode: ALL DNS to this server (leaks DNS outside tunnel!)
DNS_CUSTOM_SERVER=192.168.1.1

# Internal — set by install-server.sh based on DNS_MODE (do not edit manually)
DNS_UPSTREAM=10.64.0.1
